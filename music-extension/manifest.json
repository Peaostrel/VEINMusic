{
  "manifest_version": 3,
  "name": "VEIN Music Tracker",
  "version": "1.3.2",
  "description": "Универсальный скроблер треков для VEIN Music.",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "vein-tracker@vein.music",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://music.yandex.ru/*",
        "*://*.spotify.com/*",
        "*://music.youtube.com/*",
        "*://vk.com/*",
        "*://soundcloud.com/*",
        "*://music.apple.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["sync-key.js"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["page_world.js"],
      "matches": ["<all_urls>"]
    }
  ]
}